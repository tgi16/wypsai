{
  "entities": {
    "SavedItem": {
      "title": "Saved Library Item",
      "description": "A piece of generated marketing content saved by the user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the saved item." },
        "type": { "type": "string", "description": "The category of the content (e.g., Post, Script)." },
        "content": { "type": "string", "description": "The actual text content." },
        "uid": { "type": "string", "description": "The user ID of the owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was saved." }
      },
      "required": ["title", "type", "content", "uid", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat session with Strategy Partner AI.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message." },
        "text": { "type": "string", "description": "The message text." },
        "uid": { "type": "string", "description": "The user ID." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When it was sent." }
      },
      "required": ["role", "text", "uid", "timestamp"]
    }
  },
  "firestore": {
    "/saved_library/{itemId}": {
      "schema": "SavedItem",
      "description": "Collection of saved marketing materials."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages for a specific chat session."
    }
  }
}
